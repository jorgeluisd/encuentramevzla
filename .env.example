# --- Supabase ---
# URL pública del proyecto Supabase (https://<proyecto>.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Clave anónima (browser). NUNCA da acceso al schema `sensible`.
SUPABASE_ANON_KEY=your-anon-key

# Variantes expuestas al browser por Next.js (mismas que arriba, prefijo NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clave service role. SOLO en el servidor. Acceso elevado: jamás exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Postgres (Drizzle / migraciones) ---
# Cadena de conexión directa a Postgres 16 (Supabase). Solo backend / migraciones.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# --- (Futuro) Worker dedup/OCR ---
# REDIS_URL=redis://localhost:6379
