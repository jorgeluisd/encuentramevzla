# --- Supabase ---
# URL pública del proyecto Supabase (https://<proyecto>.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Clave anónima (browser). NUNCA da acceso al schema `sensible`.
SUPABASE_ANON_KEY=your-anon-key

# Variantes expuestas al browser por Next.js (mismas que arriba, prefijo NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clave service role. SOLO en el servidor. Acceso elevado: jamás exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Postgres (Drizzle / migraciones) ---
# Cadena de conexión directa a Postgres 16 (Supabase). Solo backend / migraciones.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# --- Anti-abuso del buscador (spec 0016) ---
# Cloudflare Turnstile: clave del sitio (browser) y secreta (servidor, siteverify).
# En local usa las claves de PRUEBA de Cloudflare (siempre pasan).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Sal para hashear la IP en el rate-limit (no reversible). Cadena aleatoria larga.
RATE_LIMIT_IP_SALT=change-me-to-a-long-random-string

# --- Correo transaccional (mail de bienvenida al personal invitado) ---
# Resend: API key (solo servidor). Si se deja vacía, el envío hace no-op (falla cerrado)
# y el alta del miembro NO se bloquea.
RESEND_API_KEY=your-resend-api-key
# Remitente verificado en Resend (dominio con SPF/DKIM). Formato: "Nombre <correo@dominio>".
MAIL_FROM=EncuéntrameVzla <no-reply@encuentramevzla.com>
# (Opcional) URL de descarga del Manual de Usuario (PDF). Si falta, el correo omite el bloque.
NEXT_PUBLIC_MANUAL_URL=

# --- (Futuro) Worker dedup/OCR ---
# REDIS_URL=redis://localhost:6379
