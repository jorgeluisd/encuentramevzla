{
  "name": "@evzla/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "reconcile": "tsx scripts/reconciliation/reconcile.ts",
    "lint": "echo \"(db) lint stub\" && exit 0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@evzla/core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@evzla/config": "workspace:*",
    "@types/node": "^22.10.7",
    "drizzle-kit": "^0.31.10",
    "exceljs": "^4.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
